<h1>Productos en tiempo real</h1>

<h2>Agregar producto</h2>

<form id="productForm">
    <input type="text" name="title" placeholder="Título" required><br><br>

    <input type="text" name="description" placeholder="Descripción" required><br><br>

    <input type="text" name="code" placeholder="Código" required><br><br>

    <input type="number" name="price" placeholder="Precio" required><br><br>

    <input type="number" name="stock" placeholder="Stock" required><br><br>

    <input type="text" name="category" placeholder="Categoría" required><br><br>

    <button type="submit">Agregar producto</button>
</form>

<hr>

<div id="productList">
    {{#if products.length}}
        <ul>
            {{#each products}}
                <li>
                    <strong>{{title}}</strong><br>
                    Descripción: {{description}}<br>
                    Código: {{code}}<br>
                    Precio: ${{price}}<br>
                    Stock: {{stock}}<br>
                    Categoría: {{category}}
                </li>
                <hr>
            {{/each}}
        </ul>
    {{else}}
        <p>No hay productos cargados.</p>
    {{/if}}
</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/realtime.js"></script>